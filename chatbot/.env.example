# Variáveis de ambiente do Assistente de Avaliação (ABOS)
# Copie para ".env.local" no desenvolvimento e configure na Vercel em produção.

# Chave da API do OpenRouter (obrigatória) — NUNCA versione a chave real.
OPENROUTER_API_KEY=sua_chave

# Modelo usado na triagem (Gemini Flash via OpenRouter).
# Centralizado aqui para não ficar fixo no código.
OPENROUTER_MODEL=google/gemini-3-flash-preview
